{
  "expo": {
    "name": "AI Kakao",
    "slug": "ai-kakao-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aikakao",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B4D1E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.itsb.lp3b.aikakao",
      "infoPlist": {
        "NSCameraUsageDescription": "AI Kakao memerlukan akses kamera untuk memindai dan mendiagnosis kondisi tanaman kakao.",
        "NSLocationWhenInUseUsageDescription": "AI Kakao memerlukan akses lokasi untuk menandai posisi GPS setiap hasil inspeksi pada peta kebun."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2E7D32"
      },
      "package": "com.itsb.lp3b.aikakao",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120,
          "resizeMode": "contain",
          "backgroundColor": "#1B4D1E"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "AI Kakao memerlukan akses kamera untuk memindai kondisi tanaman kakao."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "AI Kakao memerlukan akses lokasi untuk geo-tagging hasil inspeksi."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fc2bc87a-ee06-42d3-95e4-c5a132fb5064"
      }
    }
  }
}
